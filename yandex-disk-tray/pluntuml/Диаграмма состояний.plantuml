@startuml
!theme plain
title Состояния монитора Yandex.Disk

[*] --> Остановлен

state Остановлен {
    [*] --> Проверка_процесса
    Проверка_процесса --> Запуск : процесс не найден
    Проверка_процесса --> Ожидание : ручная остановка
}

state Запуск {
    [*] --> Старт_команда
    Старт_команда --> Ожидание_статуса
    Ожидание_статуса --> Успех : статус running
    Ожидание_статуса --> Таймаут : >5 секунд
    Таймаут --> Перезапуск
    Перезапуск --> Старт_команда
}

state Работает {
    [*] --> Синхронизация
    Синхронизация --> Ожидание_команды : "ожидание команды"
    Ожидание_команды --> Синхронизация : "синхронизация"
}

state Ожидание {
    [*] --> Ждём_команду
    Ждём_команду --> Возобновление : нажата кнопка
    Ждём_команду --> Запуск : автоматический
}

Остановлен --> Запуск : автоматический запуск
Остановлен --> Ожидание : ручная остановка
Ожидание --> Запуск : возобновить
Запуск --> Работает : успешный запуск
Работает --> Остановлен : yandex-disk stop
Работает --> Остановлен : ошибка процесса
Запуск --> Остановлен : ошибка запуска

state "Принудительная синхронизация" as ForceSync
Работает --> ForceSync : нажата кнопка
ForceSync --> Работает : синхронизация запущена

@enduml